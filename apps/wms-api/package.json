{
  "name": "@sumosave/wms-api",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --build ../../packages/shared-types/tsconfig.json && tsc --build",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest --run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1035.0",
    "@aws-sdk/client-sns": "^3.1035.0",
    "@aws-sdk/client-sqs": "^3.1035.0",
    "@aws-sdk/s3-request-presigner": "^3.1037.0",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@sumosave/shared-types": "*",
    "axios": "^1.15.2",
    "dotenv": "^16.4.7",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.10.1",
    "pg": "^8.20.0",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pg": "^8.11.0",
    "fast-check": "^3.17.0",
    "tsx": "^4.7.0",
    "typescript": "*",
    "vitest": "*"
  }
}
