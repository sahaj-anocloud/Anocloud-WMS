{
  "name": "@sumosave/db-migrations",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "migrate": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down",
    "migrate:create": "node-pg-migrate create",
    "migrate:staging": "cross-env DATABASE_URL=postgres://wms_user:wms_password@localhost:5433/wms_db node-pg-migrate up",
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "node-pg-migrate": "^6.2.0",
    "pg": "^8.11.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.0",
    "cross-env": "^10.1.0",
    "typescript": "*"
  }
}
